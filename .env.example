# Groq API key (https://console.groq.com/keys). Used for the AI diagnosis feature.
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the diagnosis model. Defaults to llama-3.3-70b-versatile.
# Other options: llama-3.1-8b-instant, openai/gpt-oss-120b, meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MODEL=llama-3.3-70b-versatile
